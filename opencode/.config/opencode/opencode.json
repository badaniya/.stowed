{
  "$schema": "https://opencode.ai/config.json",
  "keybinds": {
    "leader": "ctrl+x",
    "app_exit": "ctrl+c,<leader>q",
    "editor_open": "<leader>e",
    "theme_list": "<leader>t",
    "sidebar_toggle": "<leader>b",
    "status_view": "<leader>s",
    "session_export": "<leader>x",
    "session_new": "<leader>n",
    "session_list": "<leader>l",
    "session_timeline": "<leader>g",
    "session_share": "none",
    "session_unshare": "none",
    "session_interrupt": "escape",
    "session_compact": "<leader>c",
    "session_child_cycle": "ctrl+right",
    "session_child_cycle_reverse": "ctrl+left",
    "messages_page_up": "ctrl+b,pageup",
    "messages_page_down": "ctrl+f,pagedown",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "messages_first": "ctrl+g,home",
    "messages_last": "ctrl+e,end",
    "messages_copy": "<leader>y",
    "messages_undo": "<leader>u",
    "messages_redo": "<leader>r",
    "messages_toggle_conceal": "<leader>h",
    "model_list": "<leader>m",
    "model_cycle_recent": "f2",
    "model_cycle_recent_reverse": "shift+f2",
    "command_list": "ctrl+p",
    "agent_list": "<leader>a",
    "agent_cycle": "tab",
    "agent_cycle_reverse": "shift+tab",
    "input_clear": "ctrl+c",
    "input_forward_delete": "ctrl+w",
    "input_paste": "ctrl+v",
    "input_submit": "enter",
    "input_newline": "shift+enter",
    "history_previous": "up",
    "history_next": "down"
  },
  "tools": {
    "bash": true,
    "edit": true,
    "read": true,
    "write": true,
    "grep": false,
    "glob": false,
    "list": false,
    "todoread": false,
    "todowrite": false,
    "webfetch": true
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "github-copilot/claude-haiku-4.5",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "plan": {
      "mode": "primary",
      "model": "github-copilot/claude-haiku-4.5",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "mcphub*": false
      }
    },
  },
  "mcp": {
    "jira-remote-mcp": {
      "enabled": true,
      "url": "https://ws1-jira-mcp.qa.xcloudiq.com/mcp",
      "type": "remote",
      "headers": {"x-jira-pat": "{env:JIRA_MCP_API_TOKEN}"}
    },
    "mcphub": {
      "enabled": true,
      "url": "http://localhost:37373/mcp",
      "type": "remote"
    }
  },
}
