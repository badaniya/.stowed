#!/usr/bin/env bash
# nvo-review-branch — launch a fresh NVO-REVIEW herdr workspace for a given branch.
#
# Usage:
#   nvo-review-branch <branch-name>
#   nvo-review-branch NVO-12345/my-feature-branch
#
# What it does:
#   1. git fetch + checkout <branch> in GoDCApp (the primary review repo)
#   2. Renders the herdr-spreader template with the branch name substituted in
#   3. Runs herdr-spreader apply on the generated config

set -euo pipefail

# ── Args ─────────────────────────────────────────────────────────────────────
if [[ $# -lt 1 ]]; then
  echo "Usage: nvo-review-branch <branch-name>" >&2
  exit 1
fi

export BRANCH="${1}"

# Extract Jira ticket key from branch name (e.g. NVO-18389/... or CFD-17681/... or just NVO-18389)
export TICKET
TICKET=$(echo "${BRANCH}" | grep -oP '([A-Z]+-[0-9]+)' | head -1)
if [[ -z "${TICKET}" ]]; then
  echo "Warning: could not extract a Jira ticket key from '${BRANCH}' — JIRA pane will be empty" >&2
fi

# ── Paths ────────────────────────────────────────────────────────────────────
NVO_REVIEW_ROOT="${HOME}/workspace/badaniya/NVO-REVIEW"
GODCAPP_DIR="${NVO_REVIEW_ROOT}/GoDCApp"
TEMPLATE="${HOME}/.stowed/herdr/.config/herdr/plugins/config/herdr-spreader/nvo-review-branch.yaml.tpl"
TMP_CONFIG="/tmp/nvo-review-${BRANCH//\//-}.yaml"

# ── Checkout branch in GoDCApp ───────────────────────────────────────────────
echo "→ Fetching and checking out '${BRANCH}' in GoDCApp…"
git -C "${GODCAPP_DIR}" fetch --all --quiet
git -C "${GODCAPP_DIR}" checkout "${BRANCH}"

# ── Render the template ──────────────────────────────────────────────────────
echo "→ Rendering workspace config to ${TMP_CONFIG}…"
envsubst '${BRANCH} ${TICKET}' < "${TEMPLATE}" > "${TMP_CONFIG}"

# ── Apply the layout ─────────────────────────────────────────────────────────
echo "→ Launching herdr workspace for branch '${BRANCH}'…"
herdr-spreader apply --file "${TMP_CONFIG}"
