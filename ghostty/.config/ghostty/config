# Theme and Color Config
theme = catppuccin-mocha
foreground = ddddfd
background = 202020

# Transparency
background-opacity = 0.85
#mac-only background-blur-radius = 20

# Terminal window size
#window-height=330
#window-width=183

# Font Config
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 13.0

# Keybinds
keybind = f11=toggle_fullscreen
keybind = f12=toggle_window_decorations
## Copy/Paste
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
## Collides with NeoVIM Barbar Tabs
keybind = alt+1=unbind
keybind = alt+2=unbind
keybind = alt+3=unbind
keybind = alt+4=unbind
keybind = alt+5=unbind
keybind = alt+6=unbind
keybind = alt+7=unbind
keybind = alt+8=unbind
keybind = alt+9=unbind
keybind = alt+0=unbind
