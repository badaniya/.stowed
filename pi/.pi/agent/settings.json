    {
      "source": "npm:lsp-pi",
      "extensions": [
        "+lsp.ts"
      ]
    },
    "npm:pi-teams",
    "npm:pi-shell-completions",
    "npm:visual-explainer",
    "npm:pi-which-key",
    "npm:pi-screenshots-picker",
